<!-- CONTACT SECTION -->
<!-- ====================================================== -->

<section id="contact" class="bg-white py-32">

    <div class="max-w-6xl mx-auto px-6">

        <!-- Heading -->

        <div class="text-center mb-20">

            <h2 class="text-5xl lg:text-6xl font-bold text-[#083336]">
                LETS CONNECT
            </h2>

            <p class="text-gray-500 max-w-3xl mx-auto mt-6 leading-8">
                I'm always open to discussing new opportunities,
                freelance work, collaborations, or simply having a chat.
                Feel free to send me a message.
            </p>

        </div>

        <!-- Two Column Layout -->

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">

            <!-- ================================= -->
            <!-- LEFT SIDE -->
            <!-- ================================= -->

            <div
                id="contactInfo"
                class="bg-[#083336] rounded-[35px] p-10 lg:p-14 text-white
                       h-full flex flex-col justify-center">

                <h3 class="text-4xl font-bold mb-6 text-center lg:text-left">

                    Contact Information

                </h3>

                <p class="text-white/70 leading-8 mb-12 text-center lg:text-left">

                    Whether you're looking for a Full Stack Developer,
                    have a project in mind,
                    or simply want to connect,
                    I'd love to hear from you.

                </p>

                <div class="space-y-4 w-full">

                    <!-- Email -->

                    <div class="bg-white/10 rounded-2xl p-6">

                        <p class="uppercase text-xs tracking-[0.25em] text-white/60">

                            Email

                        </p>

                        <h4 class="text-xl font-semibold mt-2">

                            khadztimber@gmail.com

                        </h4>

                    </div>

                    <!-- Phone -->

                    <div class="bg-white/10 rounded-2xl p-6">

                        <p class="uppercase text-xs tracking-[0.25em] text-white/60">

                            Phone

                        </p>

                        <h4 class="text-xl font-semibold mt-2">

                            +255-789-666-218

                        </h4>

                    </div>

                    <!-- Location -->

                    <div class="bg-white/10 rounded-2xl p-6">

                        <p class="uppercase text-xs tracking-[0.25em] text-white/60">

                            Location

                        </p>

                        <h4 class="text-xl font-semibold mt-2">

                            Tanzania

                        </h4>

                    </div>

                    <!-- GitHub -->

                    <div class="bg-white/10 rounded-2xl p-6">

                        <p class="uppercase text-xs tracking-[0.25em] text-white/60">

                            GitHub

                        </p>

                        <a
                            href="https://github.com/khadzuu"
                            target="_blank"
                            class="text-lg font-semibold hover:underline">

                            github.com/khadija-timber

                        </a>

                    </div>

                    <!-- LinkedIn -->

                    <div class="bg-white/10 rounded-2xl p-6">

                        <p class="uppercase text-xs tracking-[0.25em] text-white/60">

                            LinkedIn

                        </p>

                        <a
                            href="https://linkedin.com/in/khadija-timber"
                            target="_blank"
                            class="text-lg font-semibold hover:underline">

                            linkedin.com/khadija

                        </a>

                    </div>

                </div>

            </div>

            <!-- ================================= -->
            <!-- RIGHT SIDE -->
            <!-- ================================= -->

            <div
                id="contactCard"
                class="bg-white border border-gray-200 rounded-[35px]
                       shadow-2xl p-10 lg:p-14
                       h-full flex flex-col justify-center">

                <h3 class="text-4xl font-bold text-[#083336] mb-4 text-center lg:text-left">

                    Send a Message

                </h3>

                <p class="text-gray-500 mb-10 text-center lg:text-left">

                    Fill out the form below and I'll get back to you
                    as soon as possible.

                </p>

                <!-- Success / Error -->

                <div
                    id="formMessage"
                    class="hidden rounded-xl px-5 py-4 mb-6 text-sm font-medium">
                </div>

                <form id="contactForm" action="/contact" method="POST" class="space-y-6">

                    <!-- Name -->

                    <div>

                        <label
                            for="name"
                            class="block font-semibold text-[#083336] mb-2">

                            Full Name

                        </label>

                        <input 
                            id="name"
                            name="name"
                            type="text"
                            required
                            placeholder="Enter your full name"
                            class="w-full rounded-xl border border-gray-300 px-5 py-4 outline-none focus:border-[#083336] transition">

                    </div>

                    <!-- Email -->

                    <div>

                        <label
                            for="email"
                            class="block font-semibold text-[#083336] mb-2">

                            Email Address

                        </label>

                        <input
                            id="email"
                            name="email"
                            type="email"
                            required
                            placeholder="Enter your email"
                            class="w-full rounded-xl border border-gray-300 px-5 py-4 outline-none focus:border-[#083336] transition">

                    </div>

                    <!-- Message -->

                    <div>

                        <label
                            for="message"
                            class="block font-semibold text-[#083336] mb-2">

                            Message

                        </label>

                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="Write your message..."
                            class="w-full rounded-xl border border-gray-300 px-5 py-4 resize-none outline-none focus:border-[#083336] transition"></textarea>

                    </div>

                    <!-- Submit -->

                    <button
                        id="submitBtn"
                        type="submit"
                        class="w-full bg-[#083336] text-white py-4 rounded-full
                               font-semibold hover:bg-[#0A4346] transition duration-300">

                        Let's Connect

                    </button>

                </form>

            </div>

        </div>

    </div>

</section>
    

       