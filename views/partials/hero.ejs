        </svg>

    </button>

    <div class="h-full flex justify-center items-center">

        <ul class="space-y-8 text-center">

            <li><a href="#home" class="menu-link text-3xl text-[#083336]">Home</a></li>

            <li><a href="#about" class="menu-link text-3xl text-[#083336]">About</a></li>

            <li><a href="#skills" class="menu-link text-3xl text-[#083336]">Skills</a></li>

            <li><a href="#projects" class="menu-link text-3xl text-[#083336]">Projects</a></li>

            <li><a href="#resume" class="menu-link text-3xl text-[#083336]">Resume</a></li>

            <li><a href="#contact" class="menu-link text-3xl text-[#083336]">Contact</a></li>

        </ul>

